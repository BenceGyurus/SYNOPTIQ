# .env.example
# Másold le .env néven és töltsd ki az értékeket!

# Database
POSTGRES_USER=solaris
POSTGRES_PASSWORD=solaris_pass
POSTGRES_DB=solaris
DATABASE_URL=postgresql+asyncpg://solaris:solaris_pass@db:5432/solaris

# Backend Security
SECRET_KEY=your_very_secret_key_change_me
ALGORITHM=HS256

# Inverter Settings
INVERTER_NAME="My Solar Inverter"
INVERTER_SERIAL=123456789
INVERTER_IP=192.168.1.100
INVERTER_PORT=8484

# Frontend
NEXT_PUBLIC_LANGUAGE=hu
